# Основная база данных (обязательно)
PGHOST=localhost
PGPORT=5432
PGDATABASE=your_database
PGUSER=your_user
PGPASSWORD=your_password
PGSSLMODE=prefer
PGCONNECT_TIMEOUT=5

# Дополнительные базы данных (опционально)
# Формат: DB_{NAME}_{PARAMETER}
# Добавьте столько баз, сколько нужно

# Пример: Тестовая база
#DB_TEST_HOST=test-host
#DB_TEST_PORT=5432
#DB_TEST_DATABASE=test_db
#DB_TEST_USER=test_user
#DB_TEST_PASSWORD=test_password
#DB_TEST_SSLMODE=prefer

# Пример: Dev база
#DB_DEV_HOST=dev-host
#DB_DEV_PORT=5432
#DB_DEV_DATABASE=dev_db
#DB_DEV_USER=dev_user
#DB_DEV_PASSWORD=dev_password

# Пример: Staging база
#DB_STAGING_HOST=staging-host
#DB_STAGING_PORT=5432
#DB_STAGING_DATABASE=staging_db
#DB_STAGING_USER=staging_user
#DB_STAGING_PASSWORD=staging_password
